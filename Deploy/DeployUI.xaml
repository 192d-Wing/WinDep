<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Windows 11 Deployment" Height="560" Width="820"
        WindowStartupLocation="CenterScreen" WindowStyle="None"
        ResizeMode="NoResize" Background="#15263B" Foreground="#FFFFFF"
        FontFamily="Segoe UI">
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#355E93"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="18,10"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" Background="{TemplateBinding Background}" CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="#4574AF"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="b" Property="Background" Value="#2A4056"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="Ghost" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#1F3C5D"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="64"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="44"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#1E3858">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="24,0">
                    <TextBlock Text="&#xE977;" FontFamily="Segoe MDL2 Assets" FontSize="22"
                               Foreground="#AEBFD4" VerticalAlignment="Center" Margin="0,0,12,0"/>
                    <TextBlock Text="Windows 11 Deployment" FontSize="20" FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                </StackPanel>
                <TextBlock x:Name="IdentityText" Text="" Foreground="#AEBFD4" FontSize="12"
                           HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,24,0"/>
            </Grid>
        </Border>

        <!-- Body: swappable panels -->
        <Grid Grid.Row="1" Margin="24">

            <!-- MODE panel -->
            <StackPanel x:Name="ModePanel" VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="Choose a deployment mode" FontSize="18" Margin="0,0,0,24"
                           HorizontalAlignment="Center" Foreground="#EBEFF5"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button x:Name="BtnInteractive" Width="240" Height="120" Margin="0,0,20,0">
                        <StackPanel>
                            <TextBlock Text="&#xE9D9;" FontFamily="Segoe MDL2 Assets" FontSize="30"
                                       HorizontalAlignment="Center" Margin="0,0,0,8"/>
                            <TextBlock Text="Interactive" FontSize="16" HorizontalAlignment="Center"/>
                            <TextBlock Text="Pick disk &amp; name" FontSize="11" Opacity="0.8"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="BtnZeroTouch" Width="240" Height="120" Style="{StaticResource Ghost}">
                        <StackPanel>
                            <TextBlock Text="&#xE945;" FontFamily="Segoe MDL2 Assets" FontSize="30"
                                       HorizontalAlignment="Center" Margin="0,0,0,8"/>
                            <TextBlock Text="Zero-Touch" FontSize="16" HorizontalAlignment="Center"/>
                            <TextBlock Text="Auto from server" FontSize="11" Opacity="0.8"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </StackPanel>

            <!-- INTERACTIVE config panel -->
            <StackPanel x:Name="ConfigPanel" Visibility="Collapsed" VerticalAlignment="Center" MaxWidth="560">
                <TextBlock Text="Interactive deployment" FontSize="18" Margin="0,0,0,18" Foreground="#EBEFF5"/>

                <TextBlock Text="Target disk (WILL BE ERASED)" FontSize="12" Foreground="#AEBFD4" Margin="0,0,0,4"/>
                <ComboBox x:Name="DiskCombo" Height="34" Margin="0,0,0,16" FontSize="13"/>

                <TextBlock Text="Computer name" FontSize="12" Foreground="#AEBFD4" Margin="0,0,0,4"/>
                <TextBox x:Name="NameBox" Height="34" Margin="0,0,0,16" FontSize="13"
                         Background="#254267" Foreground="White" BorderBrush="#3C5B84" Padding="8,6"/>

                <CheckBox x:Name="UnattendCheck" Content="Apply unattend (automate Windows OOBE)"
                          Foreground="#EBEFF5" IsChecked="True" Margin="0,0,0,20"/>

                <Border Background="#3A1F22" CornerRadius="6" Padding="12" Margin="0,0,0,20">
                    <TextBlock TextWrapping="Wrap" Foreground="#F2B8B8" FontSize="12"
                               Text="The selected disk will be completely erased. Type ERASE below to confirm."/>
                </Border>
                <TextBox x:Name="ConfirmBox" Height="34" Margin="0,0,0,20" FontSize="13"
                         Background="#254267" Foreground="White" BorderBrush="#3C5B84" Padding="8,6"/>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="BtnBack" Content="Back" Style="{StaticResource Ghost}" Margin="0,0,12,0"/>
                    <Button x:Name="BtnDeploy" Content="Erase &amp; Deploy" Width="160"/>
                </StackPanel>
            </StackPanel>

            <!-- PROGRESS panel -->
            <StackPanel x:Name="ProgressPanel" Visibility="Collapsed" VerticalAlignment="Center">
                <TextBlock x:Name="StageText" Text="Starting..." FontSize="18" Margin="0,0,0,12"
                           HorizontalAlignment="Center"/>
                <ProgressBar x:Name="Bar" Height="14" Minimum="0" Maximum="100" Value="0"
                             Foreground="#8BA7CC" Background="#254267" BorderThickness="0"/>
                <TextBlock x:Name="PercentText" Text="0%" HorizontalAlignment="Center" Margin="0,8,0,18"
                           Foreground="#AEBFD4"/>
                <Border Background="#0D1926" CornerRadius="6" Height="180" Padding="10">
                    <ScrollViewer x:Name="LogScroller" VerticalScrollBarVisibility="Auto">
                        <TextBlock x:Name="LogText" FontFamily="Consolas" FontSize="11"
                                   Foreground="#AEBFD4" TextWrapping="Wrap"/>
                    </ScrollViewer>
                </Border>
                <Button x:Name="BtnFinish" Content="Reboot" Width="160" Margin="0,18,0,0"
                        HorizontalAlignment="Center" Visibility="Collapsed"/>
            </StackPanel>

            <!-- POLICY BLOCKED panel (hard-gate remediation screen) -->
            <StackPanel x:Name="PolicyPanel" Visibility="Collapsed" VerticalAlignment="Center" MaxWidth="640">
                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                    <TextBlock Text="&#xE7BA;" FontFamily="Segoe MDL2 Assets" FontSize="22"
                               Foreground="#F2B8B8" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBlock x:Name="PolicyTitle" Text="Deployment blocked by policy" FontSize="20"
                               FontWeight="SemiBold" Foreground="#F2B8B8" VerticalAlignment="Center"/>
                </StackPanel>
                <TextBlock x:Name="PolicySummary" Foreground="#AEBFD4" FontSize="11" FontFamily="Consolas"
                           TextWrapping="Wrap" Margin="0,0,0,10"/>

                <TextBlock Text="Failed checks" FontSize="12" Foreground="#AEBFD4" Margin="0,0,0,4"/>
                <Border Background="#0D1926" CornerRadius="6" Height="92" Padding="10" Margin="0,0,0,10">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel x:Name="PolicyReasons"/>
                    </ScrollViewer>
                </Border>

                <TextBlock Text="Required remediations" FontSize="12" Foreground="#AEBFD4" Margin="0,0,0,4"/>
                <Border Background="#0D1926" CornerRadius="6" Height="66" Padding="10" Margin="0,0,0,14">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel x:Name="PolicyRemediations"/>
                    </ScrollViewer>
                </Border>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="BtnPolicyExit" Content="Exit to Command Prompt"
                            Style="{StaticResource Ghost}" Margin="0,0,12,0"/>
                    <Button x:Name="BtnRecheck" Content="Re-check" Width="140"/>
                </StackPanel>
            </StackPanel>
        </Grid>

        <!-- Footer -->
        <Border Grid.Row="2" Background="#101F31">
            <Grid>
                <TextBlock x:Name="StatusBar" Text="Ready" Foreground="#728FB4" FontSize="12"
                           VerticalAlignment="Center" Margin="24,0"/>
                <Button x:Name="BtnQuit" Content="Exit to Command Prompt" Style="{StaticResource Ghost}"
                        HorizontalAlignment="Right" Margin="0,6,16,6" Padding="12,4" FontSize="12"/>
            </Grid>
        </Border>
    </Grid>
</Window>
