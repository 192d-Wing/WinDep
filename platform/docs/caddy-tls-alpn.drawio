<mxfile host="app.diagrams.net">
  <diagram name="WinDep Caddy TLS-ALPN-01" id="windep-caddy">
    <mxGraphModel dx="1100" dy="760" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1169" pageHeight="826" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="winpe" value="WinPE target&#10;(boot.wim, trusts internal CA)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1"><mxGeometry x="40" y="140" width="170" height="60" as="geometry"/></mxCell>
        <mxCell id="adminws" value="Admin workstation&#10;(admin subnets only)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="1"><mxGeometry x="40" y="470" width="170" height="60" as="geometry"/></mxCell>
        <mxCell id="acme" value="Internal ACME CA&#10;(step-ca / smallstep)&#10;root = the CA baked into boot.wim" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1"><mxGeometry x="470" y="20" width="230" height="70" as="geometry"/></mxCell>
        <mxCell id="deployzone" value="Deploy VIP (anycast / ECMP)  —  deploy.&lt;d&gt;, windep-api.&lt;d&gt;" style="rounded=0;whiteSpace=wrap;html=1;dashed=1;fillColor=none;strokeColor=#6c8ebf;verticalAlign=top;fontStyle=2;" vertex="1" parent="1"><mxGeometry x="300" y="150" width="420" height="180" as="geometry"/></mxCell>
        <mxCell id="caddyweb" value="windep-web = Caddy (N replicas)&#10;• file_server /srv/windep&#10;• reverse_proxy /api → windep-api&#10;• TLS-ALPN-01 (certmagic)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;align=left;spacingLeft=8;" vertex="1" parent="1"><mxGeometry x="320" y="185" width="240" height="90" as="geometry"/></mxCell>
        <mxCell id="acmestore" value="certmagic storage&#10;(RWX PVC — HA challenge/cert share)" style="shape=cylinder3;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1"><mxGeometry x="590" y="185" width="110" height="90" as="geometry"/></mxCell>
        <mxCell id="api" value="windep-api&#10;(ClusterIP, PLAINTEXT, no ACME)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="800" y="150" width="200" height="60" as="geometry"/></mxCell>
        <mxCell id="payload" value="Payload PV (RWX)&#10;config/ images/*.wim boot/" style="shape=cylinder3;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="820" y="260" width="160" height="80" as="geometry"/></mxCell>
        <mxCell id="adminzone" value="Admin VIP (separate subnet)  —  NetworkPolicy ipBlock allow-list" style="rounded=0;whiteSpace=wrap;html=1;dashed=1;fillColor=none;strokeColor=#d79b00;verticalAlign=top;fontStyle=2;" vertex="1" parent="1"><mxGeometry x="300" y="440" width="420" height="150" as="geometry"/></mxCell>
        <mxCell id="adminpod" value="windep-admin pod (1 replica)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#d79b00;verticalAlign=top;fontStyle=2;" vertex="1" parent="1"><mxGeometry x="320" y="470" width="300" height="105" as="geometry"/></mxCell>
        <mxCell id="adminsidecar" value="Caddy sidecar&#10;TLS-ALPN-01 :8443" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1"><mxGeometry x="332" y="500" width="130" height="60" as="geometry"/></mxCell>
        <mxCell id="admin" value="admin (PLAINTEXT&#10;localhost:8080)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="478" y="500" width="130" height="60" as="geometry"/></mxCell>
        <mxCell id="admindb" value="admin DB (RWO)&#10;audit + telemetry" style="shape=cylinder3;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1"><mxGeometry x="800" y="470" width="150" height="70" as="geometry"/></mxCell>
        <mxCell id="e1" value="1. ACME order (TLS-ALPN-01)" style="endArrow=block;html=1;strokeColor=#82b366;dashed=1;fontColor=#2d6a2d;" edge="1" parent="1" source="caddyweb" target="acme"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e2" value="2. challenge conn (acme-tls/1) → VIP:443" style="endArrow=block;html=1;strokeColor=#82b366;dashed=1;fontColor=#2d6a2d;" edge="1" parent="1" source="acme" target="deployzone"><mxGeometry relative="1" as="geometry"><mxPoint x="300" y="120" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="e3" value="3. serve/store challenge (any replica, HA)" style="endArrow=block;startArrow=block;html=1;strokeColor=#82b366;dashed=1;fontColor=#2d6a2d;" edge="1" parent="1" source="caddyweb" target="acmestore"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e4" value="4. internal-CA cert issued" style="endArrow=block;html=1;strokeColor=#82b366;dashed=1;fontColor=#2d6a2d;" edge="1" parent="1" source="acme" target="caddyweb"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e5" value="admin sidecar: own TLS-ALPN-01 (single replica)" style="endArrow=block;startArrow=block;html=1;strokeColor=#82b366;dashed=1;fontColor=#2d6a2d;" edge="1" parent="1" source="adminsidecar" target="acme"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="fA" value="A. GET /boot /images /config (HTTPS, internal CA)" style="endArrow=block;html=1;strokeColor=#6c8ebf;fontColor=#274b73;" edge="1" parent="1" source="winpe" target="caddyweb"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="fB" value="B. file_server" style="endArrow=block;html=1;strokeColor=#6c8ebf;fontColor=#274b73;" edge="1" parent="1" source="caddyweb" target="payload"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="fC" value="C. /api/ztp/resolve + telemetry (HTTPS)" style="endArrow=block;html=1;strokeColor=#6c8ebf;fontColor=#274b73;exitX=1;exitY=0.75;entryX=0;entryY=0.5;" edge="1" parent="1" source="winpe" target="caddyweb"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="250" y="230"/></Array></mxGeometry></mxCell>
        <mxCell id="fD" value="D. reverse_proxy /api (plaintext — mTLS in follow-up)" style="endArrow=block;html=1;strokeColor=#6c8ebf;fontColor=#274b73;" edge="1" parent="1" source="caddyweb" target="api"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="fE" value="E. read + decrypt config (RO)" style="endArrow=block;html=1;strokeColor=#6c8ebf;fontColor=#274b73;" edge="1" parent="1" source="api" target="payload"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="fF" value="F. forward telemetry (ingest)" style="endArrow=block;html=1;strokeColor=#6c8ebf;fontColor=#274b73;dashed=1;" edge="1" parent="1" source="api" target="admin"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="gG" value="G. HTTPS to admin VIP (netpol allow-list)" style="endArrow=block;html=1;strokeColor=#d79b00;fontColor=#8a5a00;" edge="1" parent="1" source="adminws" target="adminsidecar"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="gH" value="H. reverse_proxy localhost (plaintext)" style="endArrow=block;html=1;strokeColor=#d79b00;fontColor=#8a5a00;" edge="1" parent="1" source="adminsidecar" target="admin"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="gI" value="I. SQLite (audit trail)" style="endArrow=block;html=1;strokeColor=#666666;fontColor=#444444;" edge="1" parent="1" source="admin" target="admindb"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="legend" value="Legend&#10;— green dashed: ACME TLS-ALPN-01 issuance (internal CA)&#10;— blue: WinPE deploy / boot&#10;— orange: admin console&#10;Caddy = TLS edge (certmagic); Go apps run PLAINTEXT behind it (no code change). Backend mTLS = follow-up PR." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#999999;align=left;spacingLeft=8;fontSize=11;" vertex="1" parent="1"><mxGeometry x="40" y="600" width="640" height="100" as="geometry"/></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
